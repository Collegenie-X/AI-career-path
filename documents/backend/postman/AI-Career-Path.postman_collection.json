            "url": "{{auth_prefix}}/social-login/"
          }
        },
        {
          "name": "POST token refresh",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{auth_prefix}}/token/refresh/"
          }
        }
      ]
